            "bit_high": 15,
            "bit_low": 15,
            "access": "RW",
            "reset_value": 0,
            "description": "Over Current Limit Setting this bit high configures the ALERT pin to be asserted if the current measurement following a conversion exceeds the value programmed in the Alert Limit Register.",
            "enum_values": null,
            "source": "evidence_verified"
          },
          {
            "name": "UCL",
            "bit_high": 14,
            "bit_low": 14,
            "access": "RW",
            "reset_value": 0,
            "description": "Under Current Limit Setting this bit high configures the ALERT pin to be asserted if the current measurement following a conversion drops below the value programmed in the Alert Limit Register.",
            "enum_values": null,
            "source": "evidence_verified"
          },
          {
            "name": "BOL",
            "bit_high": 13,
            "bit_low": 13,
            "access": "RW",
            "reset_value": 0,
            "description": "Bus Voltage Over-Voltage Setting this bit high configures the ALERT pin to be asserted if the bus voltage measurement following a conversion exceeds the value programmed in the Alert Limit Register.",
            "enum_values": null,
            "source": "evidence_verified"
          },
          {
            "name": "BUL",
            "bit_high": 12,
            "bit_low": 12,
            "access": "RW",
            "reset_value": 0,
            "description": "Bus Voltage Under-Voltage Setting this bit high configures the ALERT pin to be asserted if the bus voltage measurement following a conversion drops below the value programmed in the Alert Limit Register.",
            "enum_values": null,
            "source": "evidence_verified"
          },
          {
            "name": "POL",
            "bit_high": 11,
            "bit_low": 11,
            "access": "RW",
            "reset_value": 0,
            "description": "Power Over-Limit Setting this bit high configures the ALERT pin to be asserted if the Power calculation made following a bus voltage measurement exceeds the value programmed in the Alert Limit Register.",
            "enum_values": null,
            "source": "evidence_verified"
          },
          {
            "name": "CNVR",
            "bit_high": 10,
            "bit_low": 10,
            "access": "RW",
            "reset_value": 0,
            "description": "Conversion Ready Setting this bit high configures the ALERT pin to be asserted when the Conversion Ready Flag, Bit 3, is asserted indicating that the device is ready for the next conversion.",
            "enum_values": null,
            "source": "evidence_verified"
          },
          {
            "name": "RSVD_9_5",
            "bit_high": 9,
            "bit_low": 5,
            "access": "R",
            "reset_value": 0,
            "description": "Not used.",
            "enum_values": null,
            "source": "synthetic"
          },
          {
            "name": "AFF",
            "bit_high": 4,
            "bit_low": 4,
            "access": "R",
            "reset_value": 0,
            "description": "Alert Function Flag While only one Alert Function can be monitored at the ALERT pin at a time, the Conversion Ready can also be enabled to assert the ALERT pin. Reading the Alert Function Flag following an alert allows the user to determine if the Alert Function was the source of the Alert. When the Alert Latch Enable bit is set to Latch mode, the Alert Function Flag bit clears only when the Mask/Enable Register is read. When the Alert Latch Enable bit is set to Transparent mode, the Alert Function Flag bit is cleared following the next conversion that does not result in an Alert condition.",
            "enum_values": null,
            "source": "agent_verified"
          },
          {
            "name": "CVRF",
            "bit_high": 3,
            "bit_low": 3,
            "access": "R",
            "reset_value": 0,
            "description": "Conversion Ready Although the device can be read at any time, and the data from the last conversion is available, the Conversion Ready Flag bit is provided to help coordinate one-shot or triggered conversions. The Conversion Ready Flag bit is set after all conversions, averaging, and multiplications are complete. Conversion Ready Flag bit clears under the following conditions: 1.) Writing to the Configuration Register (except for Power-Down selection) 2.) Reading the Mask/Enable Register",
            "enum_values": null,
            "source": "agent_verified"
          },
          {
            "name": "OVF",
            "bit_high": 2,
            "bit_low": 2,
            "access": "R",
            "reset_value": 0,
            "description": "Math Overflow Flag This bit is set to '1' if an arithmetic operation resulted in an overflow error. It indicates that power data may have exceeded the maximum reportable value of 419.43 W.",
            "enum_values": null,
            "source": "agent_verified"
          },
          {
            "name": "APOL",
            "bit_high": 1,
            "bit_low": 1,
            "access": "RW",
            "reset_value": 0,
            "description": "Alert Polarity bit 1 = Inverted (active-high open collector) 0 = Normal (active-low open collector) (default)",
            "enum_values": {
              "0": "Normal (active-low)",
              "1": "Inverted (active-high)"
            },
            "source": "evidence_verified"
          },
          {
            "name": "LEN",
            "bit_high": 0,
            "bit_low": 0,
            "access": "RW",
            "reset_value": 0,
            "description": "Alert Latch Enable; configures the latching feature of the ALERT pin and Alert Flag bits. 1 = Latch enabled 0 = Transparent (default) When the Alert Latch Enable bit is set to Transparent mode, the ALERT pin and Flag bit resets to the idle states when the fault has been cleared. When the Alert Latch Enable bit is set to Latch mode, the ALERT pin and Alert Flag bit remains active following a fault until the Mask/Enable Register has been read.",
            "enum_values": {
              "0": "Transparent",
              "1": "Latch"
            },
            "source": "evidence_verified"
          }
        ],
